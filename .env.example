# ─── Google Drive ───────────────────────────────────────────────
# Path to your Google service-account JSON key file
GDRIVE_SERVICE_ACCOUNT_KEY=path/to/service_account.json
# Shared Drive folder ID (top-level parent that contains raw/parsed/styled/display/archive/logs)
GDRIVE_ROOT_FOLDER_ID=your_folder_id_here

# ─── Local Paths ───────────────────────────────────────────────
LOCAL_CACHE_DIR=data/cache
LOCAL_OUTPUT_DIR=data/output
LOCAL_DISPLAY_DIR=data/display
LOCAL_ARCHIVE_DIR=data/archive
LOCAL_STYLES_DIR=data/styles
LOCAL_METADATA_DIR=data/metadata

# ─── Algorithm ─────────────────────────────────────────────────
# "nst" or "diffusion"  (diffusion will auto-fallback to nst if unavailable)
DEFAULT_ALGORITHM=nst
# Comma-separated list of allowed algorithms
ALLOWED_ALGORITHMS=nst,diffusion

# ─── Style ─────────────────────────────────────────────────────
DEFAULT_STYLE=renaissance_portrait

# ─── Image Selection ──────────────────────────────────────────
# "latest_parsed", "random_raw", or "random_any"
SELECTION_MODE=latest_parsed

# ─── Display ──────────────────────────────────────────────────
# Pimoroni Inky Impression 13.3"  —  1600×1200 (landscape)
DISPLAY_WIDTH=1600
DISPLAY_HEIGHT=1200
DISPLAY_BORDER_PX=0
DISPLAY_ADD_TITLE=false

# ─── Scheduler ────────────────────────────────────────────────
# 24h time for daily refresh  (only used by the built-in scheduler)
SCHEDULE_TIME=06:00

# ─── Hardware / Device ────────────────────────────────────────
# "auto", "cpu", "mps", "cuda"
DEVICE_PREFERENCE=auto

# ─── Diffusion ────────────────────────────────────────────────
DIFFUSION_MODEL_ID=runwayml/stable-diffusion-v1-5
DIFFUSION_STRENGTH=0.65
DIFFUSION_GUIDANCE_SCALE=7.5
DIFFUSION_NUM_INFERENCE_STEPS=30
DIFFUSION_CONTROLNET_CONDITIONING_SCALE=0.8

# ─── NST ──────────────────────────────────────────────────────
NST_CONTENT_WEIGHT=1e5
NST_STYLE_WEIGHT=1e10
NST_NUM_STEPS=300
NST_OUTPUT_LONG_EDGE=1024

# ─── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=data/logs/inky.log

# ─── Fallback ─────────────────────────────────────────────────
FALLBACK_TO_NST=true
